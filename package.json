{
  "name": "qontract-server",
  "version": "2.0.0",
  "description": "qontract graphql server",
  "author": "Red Hat App SREs <sd-app-sre@redhat.com>",
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 24"
  },
  "scripts": {
    "watch": "rm -rf ./dist && tsc --watch",
    "build": "rm -rf ./dist && tsc",
    "server": "node ./dist/server.js",
    "lint": "eslint . --ext .ts",
    "lint-fix": "eslint . --ext .ts --fix",
    "test": "mocha",
    "update-graphql-schema": "scripts/update-graphql-schema.js test/graphql_schema.json $(find test -name '*.data.json')",
    "debug": "node --inspect --require ts-node/register src/server.ts"
  },
  "dependencies": {
    "@apollo/server": "^4.13.0",
    "@aws-sdk/client-s3": "^3.1033.0",
    "deep-diff": "1.0.2",
    "dotenv": "^16.6.1",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "graphql": "^16.13.2",
    "jsonpointer": "^5.0.1",
    "prom-client": "^15.1.3",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/chai": "4.3.12",
    "@types/express": "^5.0.6",
    "@types/mocha": "10.0.10",
    "@typescript-eslint/eslint-plugin": "5.60.1",
    "@typescript-eslint/parser": "5.60.1",
    "chai": "4.5.0",
    "chai-http": "4.4.0",
    "eslint": "8.57.1",
    "eslint-config-airbnb-base": "15.0.0",
    "eslint-plugin-import": "2.32.0",
    "mocha": "11.7.5",
    "ts-node": "10.9.2",
    "typescript": "5.8.3"
  },
  "mocha": {
    "require": "ts-node/register",
    "extensions": [
      "ts"
    ],
    "spec": [
      "test/**/*.ts"
    ]
  }
}
